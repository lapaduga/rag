# Local embedding model (Xenova/all-MiniLM-L6-v2, 384-dim)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=20

# Chat API (for RAG query mode)
CHAT_API_KEY=sk-your-api-key-here
CHAT_MODEL=deepseek-chat
CHAT_BASE_URL=https://api.deepseek.com

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Reranker settings (future use)
RERANKER_ENABLED=false
RERANKER_MODEL=rerank-model
RERANKER_THRESHOLD=0.5

# Path to documents directory
DOCUMENTS_PATH=C:\defined\front

# Server
PORT=3000
HOST=0.0.0.0

# Database path
DB_PATH=./data/rag-indexer.db

# Maximum files to index
MAX_FILES=100
