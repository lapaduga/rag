# Server
PORT=3000
HOST=0.0.0.0

# Greeting message (отображается в чате при приветствии)
GREETING_MESSAGE=Привет! Я — ассистент по кодовой базе. Задай вопрос о проекте.

# Database
DB_PATH=./data/rag-indexer.db

# Documents
# Documents (по умолчанию — текущий проект)
DOCUMENTS_PATH=.

# Embeddings
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=20

# LLM Provider: 'deepseek' or 'local' (Ollama)
LLM_PROVIDER=deepseek

# DeepSeek (cloud)
CHAT_API_KEY=your-api-key-here
CHAT_MODEL=deepseek-v4-pro
CHAT_BASE_URL=https://api.deepseek.com

# Local LLM (Ollama) — используется при LLM_PROVIDER=local
LOCAL_MODEL=qwen2.5:3b
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_NUM_THREADS=4
LOCAL_NUM_GPU=0

# RAG Settings
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.5
RAG_MAX_TOKENS=2000
RAG_TEMPERATURE=0.3
RAG_AUTO_ENABLED=true

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Pipeline settings
PIPELINE_QUERY_REWRITE=true
PIPELINE_RERANKER=true
PIPELINE_THRESHOLD=0.5
PIPELINE_TOP_K_BEFORE=20
PIPELINE_TOP_K_AFTER=5

# Cross-encoder model
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Code Review (GitHub Action)
# CHAT_API_KEY — используется из основной секции
# CHAT_MODEL / CHAT_BASE_URL — переопределяются в workflow
# REVIEW_MAX_TOKENS — максимум токенов для ответа ревьюера (по умолчанию 4096)
REVIEW_MAX_TOKENS=4096

# === File Assistant: целевой проект ===
# Путь к проекту, с которым работает ассистент (по умолчанию — текущий RAG-проект)
TARGET_PROJECT_PATH=.
# ReadOnly режим: true = только чтение/поиск, false = разрешена запись
TARGET_READ_ONLY=true
# Файлы в чёрном списке (через запятую)
TARGET_SENSITIVE_FILES=server.key,xip.io.crt,.sentryclirc,tt-site-settings.js,.env,.env.local,.env.production
# Директории в чёрном списке
TARGET_SENSITIVE_DIRS=.ssh,extraData,tmp
# Директории для игнорирования при сканировании
TARGET_IGNORE_DIRS=node_modules,.git,dist,build,coverage,.nyc_output,__pycache__,bower_components
# Лимиты
TARGET_MAX_READ_LINES=500
TARGET_MAX_SEARCH_RESULTS=100
