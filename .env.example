# Server
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./data/rag-indexer.db

# Documents
DOCUMENTS_PATH=C:\defined\front

# Embeddings
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=20

# LLM (DeepSeek)
CHAT_API_KEY=your-api-key-here
CHAT_MODEL=deepseek-chat
CHAT_BASE_URL=https://api.deepseek.com

# RAG Settings
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.5
RAG_MAX_TOKENS=2000
RAG_TEMPERATURE=0.3
RAG_AUTO_ENABLED=true

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
