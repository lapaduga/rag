# API ключ для эмбеддингов (DeepSeek или OpenAI)
EMBEDDING_API_KEY=sk-your-api-key-here
EMBEDDING_API_URL=https://api.deepseek.com/v1/embeddings
EMBEDDING_MODEL=deepseek-embedding
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=20

# Чат (DeepSeek) — для RAG-запросов (Day 22)
CHAT_API_KEY=sk-your-api-key-here
CHAT_MODEL=deepseek-chat
CHAT_BASE_URL=https://api.deepseek.com

# Параметры чанкинга
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Параметры реранкера (заглушка для Day 23)
RERANKER_ENABLED=false
RERANKER_MODEL=rerank-model
RERANKER_THRESHOLD=0.5

# Путь к папке с документами по умолчанию
DOCUMENTS_PATH=C:\defined\front

# Сервер
PORT=3000
HOST=0.0.0.0

# Путь к БД
DB_PATH=./data/rag-indexer.db

# Максимальное количество файлов для индексации
MAX_FILES=100
